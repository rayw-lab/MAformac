{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BF8PromotionReceiptSet",
  "type": "object",
  "required": ["version", "entries"],
  "properties": {
    "version": {"const": "bf8_promotion_receipt_set_v1"},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["order", "receipt_path", "receipt_id", "receipt_sha256", "subject_type", "subject_id"],
        "properties": {
          "order": {"type": "integer", "minimum": 1},
          "receipt_path": {"type": "string", "minLength": 1},
          "receipt_id": {"type": "string", "minLength": 1},
          "receipt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "subject_type": {"enum": ["primary_matrix", "secondary_tool"]},
          "subject_id": {"type": "string", "minLength": 1},
          "supersedes_receipt_id": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
