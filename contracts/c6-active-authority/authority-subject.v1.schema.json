{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "maformac://contracts/c6-active-authority/authority-subject.v1.schema.json",
  "title": "C6 Authority Subject V1",
  "description": "Subject tuple schema for the V1 active authority. Each subject element is a key-value pair that uniquely identifies the authority's scope and basis. Used in closure-package-exit-envelope subject arrays.",
  "type": "object",
  "additionalProperties": false,
  "required": ["key", "value_type", "value"],
  "properties": {
    "key": {
      "type": "string",
      "enum": [
        "authority_id",
        "authority_version",
        "ratification_decision",
        "ratification_receipt_sha256",
        "golden_threshold",
        "demo_fuzz_formula",
        "unsupported_threshold",
        "safety_threshold",
        "behavior_class_count",
        "demo_fuzz_family_count",
        "governance_axis_count",
        "readback_field_count",
        "contract_bundle_component_count",
        "authority_digest"
      ]
    },
    "value_type": {
      "enum": ["git_sha", "sha256", "string", "integer", "boolean"]
    },
    "value": {}
  }
}
