{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "c6-eval-spine/s9-subject.v1.schema.json",
  "title": "S9 exact subject tuple",
  "type": "object",
  "required": [
    "repo_head",
    "holdout_sha256",
    "holdout_row_count",
    "b7_assembled_sha256",
    "b7_compat_sha256",
    "b7_unordered_id_set_sha256",
    "b7_is_done",
    "v1_authority_digest",
    "v1_status",
    "prompt_policy_digest",
    "parser_id",
    "mock_state_digest",
    "contract_bundle_digest",
    "selector_corpus_digest",
    "mode",
    "run_id"
  ],
  "properties": {
    "repo_head": { "type": "string", "minLength": 7 },
    "holdout_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "holdout_row_count": { "type": "integer", "const": 61 },
    "b7_assembled_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "b7_compat_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "b7_unordered_id_set_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "b7_is_done": { "type": "boolean" },
    "v1_authority_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "v1_status": { "type": "string", "enum": ["CANDIDATE", "RATIFIED"] },
    "prompt_policy_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "parser_id": { "type": "string", "minLength": 1 },
    "mock_state_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "contract_bundle_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "selector_corpus_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "mode": { "type": "string", "enum": ["fixture", "dry_run", "real"] },
    "run_id": { "type": "string", "minLength": 1 },
    "seed": { "type": ["integer", "null"] }
  },
  "additionalProperties": true
}
