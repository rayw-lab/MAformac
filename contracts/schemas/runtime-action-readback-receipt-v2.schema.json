{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Runtime action readback receipt v2",
  "type": "object",
  "required": ["schemaVersion", "receiptID", "proofClass", "caseCount", "cases", "runID", "sourceHeadSHA", "testedCheckoutSHA", "nonce", "buildIdentity", "modelIdentity", "runtimeContractBundleDigest", "probe_catalog_sha256"],
  "properties": {
    "schemaVersion": {"const": "runtime_action_readback_receipt_v2"},
    "receiptID": {"type": "string"}, "probePackSHA256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "proofClass": {"type": "string"}, "caseCount": {"type": "integer", "minimum": 1},
    "runID": {"type": "string"}, "sourceHeadSHA": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "testedCheckoutSHA": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "nonce": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "buildIdentity": {"type": "string", "minLength": 1}, "modelIdentity": {"type": "string", "minLength": 1},
    "runtimeContractBundleDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "probe_catalog_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "scope": {
      "type": "object",
      "required": ["matrix_ids"],
      "properties": {
        "matrix_ids": { "type": "array", "items": { "type": "integer" }, "minItems": 1 },
        "knife": { "type": "string" }
      },
      "additionalProperties": false
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["probeID", "matrixID", "representativeTool", "requiredEmittedToolName", "requiredActionPrimitive", "emittedToolNames", "emittedActionPrimitive", "observedToolCallCount", "stateMutation", "stateDeltas", "confirmedState", "resultKind", "reconciliationStatus", "readbacks"],
        "properties": {
          "probeID": {"type": "string", "pattern": "^probe\\.action\\.matrix\\.\\d+\\.zh-CN$"},
          "matrixID": {"type": "integer"},
          "register": {"type": "string"},
          "utterance": {"type": "string"},
          "representativeTool": {"type": "string", "minLength": 1},
          "requiredEmittedToolName": {"type": "string", "minLength": 1},
          "requiredActionPrimitive": {"type": "string", "minLength": 1},
          "emittedActionPrimitive": {"type": "string", "minLength": 1},
          "pathKind": {"type": "string"},
          "injectionUsed": {"type": "boolean"},
          "acceptanceRouteID": {"type": "string"},
          "traceID": {"type": "string"},
          "stageTraceIDs": {"type": "object"},
          "observedToolCallCount": {"type": "integer"},
          "emittedToolNames": {"type": "array", "items": {"type": "string"}},
          "stateBeforeSHA256": {"type": "string"},
          "stateAfterSHA256": {"type": "string"},
          "stateMutation": {"type": "boolean"},
          "stateDeltas": {"type": "array"},
          "confirmedState": {"type": "object"},
          "resultKind": {"type": "string"},
          "reconciliationStatus": {"type": "string"},
          "readbacks": {"type": "array"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
