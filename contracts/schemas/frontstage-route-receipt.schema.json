{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "run_id", "run_nonce", "source_head_sha", "tested_checkout_sha", "session_id", "turn_id", "event_id", "sequence", "matrix_id", "matrix_source_sha256", "runtime_contract_bundle_digest", "app_executable_sha256", "proof_class", "result", "state_mutation", "readback_count"
  ],
  "properties": {
    "schema_version": {"const": "frontstage_route_receipt.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "run_nonce": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "source_head_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "tested_checkout_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "session_id": {"type": "string", "minLength": 1},
    "turn_id": {"type": "string", "minLength": 1},
    "event_id": {"type": "string", "minLength": 1},
    "sequence": {"type": "integer", "minimum": 1},
    "matrix_id": {"type": ["integer", "null"]},
    "matrix_source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "runtime_contract_bundle_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "app_executable_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "proof_class": {"const": "frontstage_route_local_integration"},
    "result": {"const": "refusal_no_available_tool"},
    "state_mutation": {"const": false},
    "readback_count": {"const": 0}
  }
}
