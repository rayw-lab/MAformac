{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maformac.local/schemas/paper-to-skill-gate/gate-packet.schema.json",
  "title": "MAformac Paper To Skill Gate Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "paper",
    "sources",
    "official_repo",
    "reference_repo_influences",
    "algorithm_traits",
    "maformac_insertion_points",
    "openspec_candidates",
    "deliverables",
    "gate",
    "residual_risks"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "paper-to-skill-gate.v1" },
    "generated_at": { "type": "string", "minLength": 1 },
    "paper": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "paper_type", "year", "identity_confidence"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "paper_type": { "type": "string", "minLength": 1 },
        "year": { "type": "integer" },
        "venue": { "type": "string" },
        "arxiv_id": { "type": "string" },
        "doi": { "type": "string" },
        "identity_confidence": {
          "type": "string",
          "enum": ["live_verified", "local_static", "paper_only", "stale_candidate"]
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url", "evidence_type"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "minLength": 1 },
          "evidence_type": {
            "type": "string",
            "enum": ["paper", "official_repo", "project_page", "local_code", "web_metadata"]
          },
          "notes": { "type": "string" }
        }
      }
    },
    "official_repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "repo", "local_path", "code_mapping_status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["cloned", "found_not_cloned", "no_official_repo_found", "not_applicable"]
        },
        "repo": { "type": "string" },
        "url": { "type": "string" },
        "stars": { "type": ["integer", "null"] },
        "pushed_at": { "type": ["string", "null"] },
        "local_path": { "type": "string" },
        "local_head": { "type": ["string", "null"] },
        "code_mapping_status": {
          "type": "string",
          "enum": ["CODE_CONFIRMED", "PAPER_ONLY", "CODE_ONLY", "CODE_CONFLICT", "UNSPECIFIED", "NO_REPO"]
        }
      }
    },
    "reference_repo_influences": {
      "type": "array",
      "minItems": 6,
      "items": { "type": "string", "minLength": 1 }
    },
    "algorithm_traits": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "maformac_insertion_points": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "lane", "recommendation", "proof_class"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "lane": { "type": "string", "minLength": 1 },
          "recommendation": { "type": "string", "minLength": 1 },
          "proof_class": {
            "type": "string",
            "enum": ["web_verified", "local_static_teardown", "schema_validated", "not_executed", "blocked"]
          }
        }
      }
    },
    "openspec_candidates": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "deliverables": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "minLength": 1 }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "proof_class", "rationale", "stop_conditions"],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "adopt_now",
            "adopt_after_default_scope",
            "retrain_c5_input",
            "rebuild_c6_input",
            "spike_only",
            "defer",
            "reject"
          ]
        },
        "proof_class": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["web_verified", "local_static_teardown", "schema_validated", "not_executed", "blocked"]
          }
        },
        "rationale": { "type": "string", "minLength": 1 },
        "stop_conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "residual_risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
